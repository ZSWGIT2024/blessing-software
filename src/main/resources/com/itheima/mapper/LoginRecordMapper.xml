<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.LoginRecordMapper">

    <resultMap id="loginRecordMap" type="com.itheima.pojo.LoginRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="phone" column="phone"/>
        <result property="loginType" column="login_type"/>
        <result property="loginIp" column="login_ip"/>
        <result property="loginLocation" column="login_location"/>
        <result property="deviceInfo" column="device_info"/>
        <result property="browser" column="browser"/>
        <result property="os" column="os"/>
        <result property="status" column="status"/>
        <result property="failReason" column="fail_reason"/>
        <result property="loginTime" column="login_time"/>
        <result property="logoutTime" column="logout_time"/>
        <result property="onlineDuration" column="online_duration"/>
    </resultMap>

    <select id="selectPage" resultMap="loginRecordMap">
        SELECT * FROM login_record
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="loginType != null and loginType != ''">
                AND login_type = #{loginType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null and startTime != ''">
                AND login_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND login_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY login_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="countTotal" resultType="java.lang.Long">
        SELECT COUNT(*) FROM login_record
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="loginType != null and loginType != ''">
                AND login_type = #{loginType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null and startTime != ''">
                AND login_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND login_time &lt;= #{endTime}
            </if>
        </where>
    </select>

</mapper>
