<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.OperationLogMapper">

    <resultMap id="operationLogMap" type="com.itheima.pojo.OperationLog">
        <id property="id" column="id"/>
        <result property="module" column="module"/>
        <result property="operation" column="operation"/>
        <result property="type" column="type"/>
        <result property="method" column="method"/>
        <result property="requestUrl" column="request_url"/>
        <result property="requestIp" column="request_ip"/>
        <result property="requestParams" column="request_params"/>
        <result property="responseResult" column="response_result"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="duration" column="duration"/>
        <result property="status" column="status"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectPage" resultMap="operationLogMap">
        SELECT * FROM operation_log
        <where>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null and startTime != ''">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="countTotal" resultType="java.lang.Long">
        SELECT COUNT(*) FROM operation_log
        <where>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null and startTime != ''">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
    </select>

</mapper>
